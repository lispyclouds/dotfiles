background-opacity = 0.95
cursor-style = "block"
cursor-style-blink = false
font-family = "Iosevka Term"
# Fallback for symbols
font-family = "Symbols Nerd Font Mono"
font-size = 11
font-style = Heavy

keybind = ctrl+s=new_split:down
keybind = ctrl+shift+0=reset_font_size
keybind = ctrl+shift+backspace=clear_screen
keybind = ctrl+shift+h=goto_split:left
keybind = ctrl+shift+j=goto_split:down
keybind = ctrl+shift+k=goto_split:up
keybind = ctrl+shift+l=goto_split:right
keybind = ctrl+shift+minus=decrease_font_size:1
keybind = ctrl+shift+plus=increase_font_size:1
keybind = ctrl+shift+s=new_split:right
keybind = ctrl+shift+w=close_surface

